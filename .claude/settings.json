{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch --list:*)",
      "Bash(git branch -a:*)",
      "Bash(git branch -r:*)",
      "Bash(git branch -v:*)",
      "Bash(git rev-parse:*)",
      "Bash(git diff --stat:*)",
      "Bash(git diff --name-only:*)",
      "Bash(git diff --name-status:*)",
      "Bash(git log --oneline)",
      "Bash(git log -1)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(./scripts/check_agents_consistency.sh)",
      "Bash(./scripts/test_baseline_hook.sh)",
      "Bash(./scripts/lint_ai_pr_guard_workflow.sh)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Read(**/id_rsa*)",
      "Read(**/*.crt)",
      "Edit(**/.env*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/credentials.json)",
      "Edit(**/id_rsa*)",
      "Edit(**/*.crt)",
      "Write(**/.env*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/credentials.json)",
      "Write(**/id_rsa*)",
      "Write(**/*.crt)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh -c 'for py in /usr/bin/python3 /opt/homebrew/bin/python3 /usr/local/bin/python3 python3 python; do if { [ -x \"$py\" ] || command -v \"$py\" >/dev/null 2>&1; } && \"$py\" -c \"import sys; raise SystemExit(0 if sys.version_info >= (3, 8) else 1)\" >/dev/null 2>&1; then exec \"$py\" .claude/hooks/protect-sensitive-files.py; fi; done; echo \"protect-sensitive-files: BLOCKED \u2014 no Python >= 3.8 interpreter found\" >&2; exit 2'"
          }
        ]
      }
    ]
  }
}
