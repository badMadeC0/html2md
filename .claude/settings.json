{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git diff --stat:*)",
      "Bash(git diff --name-only:*)",
      "Bash(git diff --name-status:*)",
      "Bash(git log --oneline:*)",
      "Bash(git log -1)",
      "Bash(git log --pretty=format:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(./scripts/check_agents_consistency.sh)",
      "Bash(./scripts/test_baseline_hook.sh)",
      "Bash(./scripts/lint_ai_pr_guard_workflow.sh)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Read(**/id_rsa*)",
      "Read(**/*.crt)",
      "Read(**/secret.*)",
      "Read(**/secrets.*)",
      "Read(**/*.secret)",
      "Read(**/*.secret.*)",
      "Read(**/*.secrets)",
      "Read(**/*.secrets.*)",
      "Read(**/*api-token*)",
      "Read(**/*api_token*)",
      "Read(**/*-credentials.*)",
      "Read(**/*_credentials.*)",
      "Edit(**/.env*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/credentials.json)",
      "Edit(**/id_rsa*)",
      "Edit(**/*.crt)",
      "Edit(**/secret.*)",
      "Edit(**/secrets.*)",
      "Edit(**/*.secret)",
      "Edit(**/*.secret.*)",
      "Edit(**/*.secrets)",
      "Edit(**/*.secrets.*)",
      "Edit(**/*api-token*)",
      "Edit(**/*api_token*)",
      "Edit(**/*-credentials.*)",
      "Edit(**/*_credentials.*)",
      "Write(**/.env*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/credentials.json)",
      "Write(**/id_rsa*)",
      "Write(**/*.crt)",
      "Write(**/secret.*)",
      "Write(**/secrets.*)",
      "Write(**/*.secret)",
      "Write(**/*.secret.*)",
      "Write(**/*.secrets)",
      "Write(**/*.secrets.*)",
      "Write(**/*api-token*)",
      "Write(**/*api_token*)",
      "Write(**/*-credentials.*)",
      "Write(**/*_credentials.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/protect-sensitive-files.py"
          }
        ]
      }
    ]
  }
}
