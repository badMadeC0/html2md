{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch --list)",
      "Bash(git branch -a)",
      "Bash(git branch -a --list)",
      "Bash(git branch -r)",
      "Bash(git branch -r --list)",
      "Bash(git branch -v)",
      "Bash(git branch -v -a)",
      "Bash(git branch -v -r)",
      "Bash(git branch -vv)",
      "Bash(git rev-parse:*)",
      "Bash(git diff --stat)",
      "Bash(git diff --name-only)",
      "Bash(git diff --name-only HEAD)",
      "Bash(git diff --name-only origin/main)",
      "Bash(git diff --name-only origin/main...HEAD)",
      "Bash(git diff --name-status)",
      "Bash(git diff --name-status HEAD)",
      "Bash(git diff --name-status origin/main)",
      "Bash(git diff --name-status origin/main...HEAD)",
      "Bash(git log --oneline)",
      "Bash(git log -1)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(./scripts/check_agents_consistency.sh)",
      "Bash(./scripts/test_baseline_hook.sh)",
      "Bash(./scripts/lint_ai_pr_guard_workflow.sh)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.crt)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(**/id_dsa*)",
      "Read(**/secrets)",
      "Read(**/secret)",
      "Read(**/credentials)",
      "Read(**/secrets.*)",
      "Read(**/secret.*)",
      "Read(**/credentials.*)",
      "Read(**/*.secret)",
      "Read(**/*.secret.*)",
      "Read(**/*.secrets)",
      "Read(**/*.secrets.*)",
      "Read(**/*api-token*)",
      "Read(**/*api_token*)",
      "Read(**/*-credentials)",
      "Read(**/*_credentials)",
      "Read(**/*-credentials.*)",
      "Read(**/*_credentials.*)",
      "Read(**/secrets/**)",
      "Read(**/secret/**)",
      "Read(**/credentials/**)",
      "Edit(**/.env*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*.crt)",
      "Edit(**/id_rsa*)",
      "Edit(**/id_ed25519*)",
      "Edit(**/id_ecdsa*)",
      "Edit(**/id_dsa*)",
      "Edit(**/secrets)",
      "Edit(**/secret)",
      "Edit(**/credentials)",
      "Edit(**/secrets.*)",
      "Edit(**/secret.*)",
      "Edit(**/credentials.*)",
      "Edit(**/*.secret)",
      "Edit(**/*.secret.*)",
      "Edit(**/*.secrets)",
      "Edit(**/*.secrets.*)",
      "Edit(**/*api-token*)",
      "Edit(**/*api_token*)",
      "Edit(**/*-credentials)",
      "Edit(**/*_credentials)",
      "Edit(**/*-credentials.*)",
      "Edit(**/*_credentials.*)",
      "Edit(**/secrets/**)",
      "Edit(**/secret/**)",
      "Edit(**/credentials/**)",
      "Write(**/.env*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.crt)",
      "Write(**/id_rsa*)",
      "Write(**/id_ed25519*)",
      "Write(**/id_ecdsa*)",
      "Write(**/id_dsa*)",
      "Write(**/secrets)",
      "Write(**/secret)",
      "Write(**/credentials)",
      "Write(**/secrets.*)",
      "Write(**/secret.*)",
      "Write(**/credentials.*)",
      "Write(**/*.secret)",
      "Write(**/*.secret.*)",
      "Write(**/*.secrets)",
      "Write(**/*.secrets.*)",
      "Write(**/*api-token*)",
      "Write(**/*api_token*)",
      "Write(**/*-credentials)",
      "Write(**/*_credentials)",
      "Write(**/*-credentials.*)",
      "Write(**/*_credentials.*)",
      "Write(**/secrets/**)",
      "Write(**/secret/**)",
      "Write(**/credentials/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK=\"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/protect-sensitive-files.py\"; if [ -x /usr/bin/python3 ]; then exec /usr/bin/python3 \"$HOOK\"; elif [ -x /opt/homebrew/bin/python3 ]; then exec /opt/homebrew/bin/python3 \"$HOOK\"; elif command -v python3 >/dev/null 2>&1; then exec python3 \"$HOOK\"; elif command -v python >/dev/null 2>&1; then exec python \"$HOOK\"; else echo 'protect-sensitive-files: BLOCKED — no python interpreter' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}
